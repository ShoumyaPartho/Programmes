{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "compile cpp",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++17",
                "-Wall",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}.exe"
            ],
            "group": "none",
            "problemMatcher": ["$gcc"],
            "options": {
                "cwd": "${fileDirname}"
            }
        },
        {
            "label": "run exe (freopen)",
            "type": "shell",
            "command": "${fileDirname}/${fileBasenameNoExtension}.exe",
            "args": [],
            "problemMatcher": [],
            "options": {
                "cwd": "${fileDirname}"
            }
        },
        {
            "label": "Build & Run C++",
            "dependsOn": ["compile cpp", "run exe (freopen)"],
            "dependsOrder": "sequence",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "clear": true
            }
        }
    ]
}
