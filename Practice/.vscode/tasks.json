{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "compile cpp",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++17",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}",
                "${file}"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "detail": "Compile the C++ code"
        },
        {
            "label": "run cpp (with IO redirection)",
            "type": "shell",
            "command": "${fileDirname}/${fileBasenameNoExtension} < ${fileDirname}/input.txt > ${fileDirname}/output.txt",
            "dependsOn": "compile cpp",
            "problemMatcher": [],
            "detail": "Run compiled program using input.txt and write to output.txt"
        }
    ]
}
